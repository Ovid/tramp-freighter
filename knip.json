{
  "entry": ["src/main.jsx"],
  "project": ["src/**/*.{js,jsx}"],
  "paths": {
    "@/*": ["./src/*"],
    "@components/*": ["./src/components/*"],
    "@features/*": ["./src/features/*"],
    "@hooks/*": ["./src/hooks/*"],
    "@context/*": ["./src/context/*"],
    "@game/*": ["./src/game/*"],
    "@assets/*": ["./src/assets/*"]
  },
  "ignore": ["src/game/utils/dev-logger.js"]
}
